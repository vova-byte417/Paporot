-            Some(o) => o,
-            None => continue, // 上游未产出则跳过
-        };
-
-        if output.is_empty() || output == "{}" {
-            continue;
-        }
-
-        let artifact_type = skill_to_artifact_type(skill_name);
-
-        // 1. Contract 验证
-        let verify_result_json = verify_contract(artifact_type, &output)
-            .unwrap_or_else(|| {
-                format!(
